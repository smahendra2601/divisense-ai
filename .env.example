# DiviSense AI — API keys (copy to .env and fill in)
GROQ_API_KEY=
GOOGLE_API_KEY=

# Optional: recent-news context for the Forecast Agent (src/news.py).
# Without this key the pipeline runs identically, just without news
# context — it is never required. Get a free key at https://tavily.com
TAVILY_API_KEY=

# Optional, production only: gates the whole Streamlit app behind a shared
# password (see app.py's _require_password). Leave unset for local dev —
# the app runs exactly as before with no prompt. Set this in Render's
# dashboard, not here.
APP_PASSWORD=
